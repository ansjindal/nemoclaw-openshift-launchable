# Copy to .env and fill in. Sourced by scripts/setup.sh.
# NEVER commit the filled-in .env (see .gitignore).

# --- NemoClaw / REMOTE inference endpoint ---
# No local GPU: inference is served by a remote endpoint (NIM, OpenAI-compatible, etc.).
NEMOCLAW_AGENT="openclaw"                 # openclaw | hermes | langchain
NEMOCLAW_SANDBOX_NAME="workshop-sandbox"
NEMOCLAW_INFERENCE_PROVIDER="nvidia"      # provider key NemoClaw onboard expects
NEMOCLAW_INFERENCE_BASE_URL=""            # remote endpoint URL, e.g. https://integrate.api.nvidia.com/v1
NEMOCLAW_MODEL=""                         # model id served by the remote endpoint
NEMOCLAW_API_KEY=""                       # credential for the remote endpoint
NEMOCLAW_POLICY_TIER="balanced"           # restricted | balanced | open
NEMOCLAW_POLICY_FILE="policies/openclaw-sandbox.yaml"   # OpenClaw sandbox policy applied at onboard
# Fixed password for the OpenClaw Control UI (--auth password). The first browser also
# needs one-time device pairing from the lab shell. Change the password for any shared instance.
OPENCLAW_GATEWAY_PASSWORD="openclaw"

# --- MicroShift via MINC (MicroShift in Container, OKD build) ---
MINC_VERSION="latest"                     # MINC release to download
MINC_HTTPS_PORT="9443"                    # MicroShift API/ingress HTTPS (MINC default)
MINC_HTTP_PORT="9080"                     # MicroShift ingress HTTP (MINC default)
# NOTE: MINC requires PODMAN. Docker fails (nested CRI-O can't create its layer store on
# Docker's read-only overlay mount). Verified on the Brev box — keep this 'podman'.
CONTAINER_ENGINE="podman"                 # podman (required) | docker (broken with MINC)
MINC_NODE_CONTAINER="microshift"          # name of the MINC node container (phases 20/50)

# --- Host NodePort publishing (phase 50) ---
# MINC only publishes 9080/9443/6443 out of the container; NodePorts live inside it.
# Phase 50 installs a systemd forwarder so these are reachable on the host / a Brev URL.
NODEPORT_FORWARDS="30789 30900 30808 30030" # OpenClaw, console, OpenShell CLI, optional Grafana
# 0.0.0.0 = reachable via a Brev URL / remote. The console NodePort (30900) is an
# UNAUTHENTICATED admin console — set 127.0.0.1 to restrict to loopback/SSH tunnels only.
NODEPORT_BIND_ADDR="0.0.0.0"

# --- OpenShift/OKD web console (phase 60) ---
# Deployed by setup.sh by default. It's an UNAUTHENTICATED, cluster-admin console —
# fine for an ephemeral workshop box, not for anything real. Set false to skip it.
DEPLOY_CONSOLE="true"

# --- ghcr.io pull auth (OPTIONAL but recommended for reliability) ---
# Anonymous ghcr.io pulls get throttled (unexpected-EOF on large layers) after repeated pulls.
# A GitHub token with read:packages raises the limit and makes the OpenClaw image pull reliable.
GHCR_USER=""                              # GitHub username (or leave blank → oauth2)
GHCR_TOKEN=""                             # GitHub PAT with read:packages

# --- OpenShell ---
OPENSHELL_NAMESPACE="openshell"
OPENSHELL_CHART="oci://ghcr.io/nvidia/openshell/helm-chart"
OPENSHELL_VERSION=""                      # pin a chart version; blank = latest

# OpenClaw sandbox image — custom build (community base + openclaw@2026.6.10) that enables
# the DuckDuckGo web-search plugin. Override to use a different image/version.
OPENCLAW_SANDBOX_IMAGE="ghcr.io/ansjindal/openclaw-sandbox:2026.6.10"
