{
  "network_policies": [
    {
      "name": "inference",
      "endpoints": [
        { "host": "integrate.api.nvidia.com", "port": 443, "protocol": "rest", "enforcement": "enforce" }
      ],
      "binaries": ["/usr/bin/node", "/usr/bin/python*"],
      "rules": [{ "method": "POST", "path": "/v1/**" }]
    },
    {
      "name": "clawhub",
      "endpoints": [
        { "host": "clawhub.nvidia.com", "port": 443, "protocol": "rest", "enforcement": "enforce" }
      ],
      "binaries": ["/usr/bin/node"],
      "rules": [{ "method": "GET", "path": "/**" }]
    },
    {
      "name": "openclaw",
      "endpoints": [
        { "host": "api.openclaw.ai", "port": 443, "protocol": "rest", "enforcement": "enforce" },
        { "host": "docs.openclaw.ai", "port": 443, "protocol": "rest", "enforcement": "enforce" }
      ],
      "binaries": ["/usr/bin/node"],
      "rules": [{ "method": "GET", "path": "/**" }]
    },
    {
      "name": "npm",
      "endpoints": [
        { "host": "registry.npmjs.org", "port": 443, "protocol": "rest", "access": "full" }
      ],
      "binaries": ["/usr/bin/npm", "/usr/bin/node"]
    },
    {
      "name": "pypi",
      "endpoints": [
        { "host": "pypi.org", "port": 443, "protocol": "rest", "access": "full" },
        { "host": "files.pythonhosted.org", "port": 443, "protocol": "rest", "access": "full" }
      ],
      "binaries": ["/usr/bin/pip*", "/usr/bin/python*"]
    },
    {
      "name": "huggingface",
      "endpoints": [
        { "host": "huggingface.co", "port": 443, "protocol": "rest", "enforcement": "enforce" }
      ],
      "binaries": ["/usr/bin/python*"],
      "rules": [{ "method": "GET", "path": "/**" }]
    }
  ],
  "filesystem": {
    "read_write": ["/sandbox", "/tmp"],
    "read_only": ["/usr", "/etc", "/lib", "/bin"]
  },
  "process": {
    "allowed_binaries": [
      "/usr/bin/node",
      "/usr/bin/npm",
      "/usr/bin/python*",
      "/usr/bin/pip*",
      "/bin/sh",
      "/bin/bash"
    ]
  }
}
