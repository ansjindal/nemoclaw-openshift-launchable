# OpenClaw workshop lab shell — sourced by the in-browser terminal (server.mjs).
export KUBECONFIG="${KUBECONFIG:-$LAB_CWD/kubeconfig}"
export PATH="$PATH:/usr/local/bin"

# `openclaw ...` runs the OpenClaw CLI INSIDE the agent pod (the gateway host),
# where it uses the gateway's local owner identity — so `openclaw devices list`
# and `openclaw devices approve <id>` work without tokens/passwords.
openclaw() {
  oc -n openclaw exec openclaw-sandbox -c openclaw -- node dist/index.js "$@"
}

PS1='\[\e[1;32m\]oclaw-lab\[\e[0m\]:\[\e[1;34m\]\w\[\e[0m\]$ '

echo -e "\e[1;32m🦞 OpenClaw workshop lab shell\e[0m"
echo -e "  \e[2mcluster:\e[0m  oc get pods -A"
echo -e "  \e[2magent:\e[0m    openclaw devices list   (runs inside the agent pod)"
echo
