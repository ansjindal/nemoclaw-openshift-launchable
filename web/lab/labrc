# OpenClaw workshop lab shell — sourced by the in-browser terminal (server.mjs).
export KUBECONFIG="${KUBECONFIG:-$LAB_CWD/kubeconfig}"
# /usr/local/bin (oc) + /usr/bin (openshell CLI, installed by phase 70).
export PATH="$PATH:/usr/local/bin:/usr/bin"

# Load .env (for OPENCLAW_GATEWAY_PASSWORD, etc.) if present.
[ -f "$LAB_CWD/.env" ] && { set -a; . "$LAB_CWD/.env" 2>/dev/null; set +a; }

# `sbox-openclaw ...` is a LAB-SHELL HELPER (not the real binary — there's no openclaw on
# this host). It runs the OpenClaw CLI INSIDE your agent's sandbox via the OpenShell gateway
# (`openshell sandbox exec -n shifty -- openclaw ...`). For gateway subcommands (devices,
# health, logs, …) it also adds `--url`/`--password` so they reach the in-sandbox gateway on
# :30789 (password = OPENCLAW_GATEWAY_PASSWORD, default openshell-wad26). Set OPENCLAW_AGENT
# to target a different sandbox name (default: shifty). Named distinctly so it's never
# mistaken for running openclaw locally.
sbox-openclaw() {
  local extra=()
  case "$1" in
    devices|health|approvals|cron|logs)
      extra=(--url "ws://127.0.0.1:30789" --password "${OPENCLAW_GATEWAY_PASSWORD:-openshell-wad26}") ;;
  esac
  openshell sandbox exec -n "${OPENCLAW_AGENT:-shifty}" -- openclaw "$@" "${extra[@]}"
}

# expose-agent <sandbox> [port=8000] — publish a sandbox's HTTP endpoint at a host port so
# you can demo your copilot via the Brev URL. A gateway sandbox is network-isolated by its
# supervisor (the agent's port lives in a private netns), so a plain NodePort can't reach it
# — we use OpenShell's own `forward`, which bridges the port through the gateway+supervisor.
expose-agent() {
  local sb="${1:?usage: expose-agent <sandbox> [port=8000]}" port="${2:-8000}"
  openshell forward stop >/dev/null 2>&1
  if openshell forward start "0.0.0.0:$port" "$sb" --background >/dev/null 2>&1; then
    echo "✓ forwarding host :$port → $sb — open host port $port on your Brev instance to demo it"
    echo "  (stop with: openshell forward stop)"
  else
    echo "✗ forward failed — is $sb Running and serving HTTP on :$port?"
  fi
}

